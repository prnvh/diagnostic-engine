{
  "functions": {
    "api/*.mjs": {
      "maxDuration": 10,
      "includeFiles": "{diagnostic_engine,web}/**/*"
    },
    "api/**/*.mjs": {
      "maxDuration": 10,
      "includeFiles": "{diagnostic_engine,web}/**/*"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/session/start",
      "destination": "/api/session/start"
    },
    {
      "source": "/session/answer",
      "destination": "/api/session/answer"
    },
    {
      "source": "/session/([^/]+)/ledger",
      "destination": "/api/session/ledger?sessionId=$1"
    },
    {
      "source": "/session/([^/]+)",
      "destination": "/api/session/get?sessionId=$1"
    },
    {
      "source": "/",
      "destination": "/api/web?path=/"
    },
    {
      "source": "/(.*)",
      "destination": "/api/web?path=/$1"
    }
  ]
}
